{
  "manifest_version": 3,
  "name": "Trust Intelligence Platform",
  "version": "1.0.0",
  "description": "Risk intelligence sidebar for seller order review.",
  "permissions": [
    "storage",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "http://127.0.0.1:8000/*",
    "http://localhost:8000/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Trust Intelligence Platform",
    "default_popup": "popup.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://sellercentral.amazon.in/*",
        "https://sellercentral.amazon.com/*",
        "https://seller.flipkart.com/*",
        "http://localhost/*",
        "http://127.0.0.1/*"
      ],
      "js": [
        "content_amazon.js"
      ],
      "run_at": "document_idle"
    }
  ]
}