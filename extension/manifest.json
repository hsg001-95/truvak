{
  "manifest_version": 3,
  "name": "Trust Intelligence Platform",
  "version": "1.0.0",
  "description": "Risk intelligence sidebar for seller order review.",
  "permissions": [
    "storage",
    "activeTab",
    "tabs",
    "scripting",
    "alarms",
    "notifications"
  ],
  "host_permissions": [
    "http://127.0.0.1:8000/*",
    "http://localhost:8000/*",
    "https://api.truvak.com/*",
    "https://sellercentral.amazon.in/*",
    "https://sellercentral.amazon.com/*",
    "https://seller.flipkart.com/*",
    "https://www.amazon.in/*",
    "https://amazon.in/*",
    "https://www.flipkart.com/*",
    "https://flipkart.com/*",
    "https://www.croma.com/*",
    "https://croma.com/*",
    "https://www.tatacliq.com/*",
    "https://tatacliq.com/*",
    "https://www.meesho.com/*",
    "https://meesho.com/*",
    "https://www.myntra.com/*",
    "https://myntra.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Trust Intelligence Platform",
    "default_popup": "popup.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://sellercentral.amazon.in/*",
        "https://sellercentral.amazon.com/*",
        "https://seller.flipkart.com/*",
        "https://www.amazon.in/*",
        "https://amazon.in/*",
        "https://www.flipkart.com/*",
        "https://flipkart.com/*",
        "http://localhost/*",
        "http://127.0.0.1/*"
      ],
      "js": [
        "selectors.js",
        "customer_sidebar.js",
        "customer_extractor.js",
        "section_price_intel.js",
        "dark_pattern_detector.js",
        "order_scraper.js",
        "content_amazon.js",
        "content_flipkart.js"
      ],
      "run_at": "document_idle"
    }
  ]
}